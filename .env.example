# Copy this file to .env and fill in from Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Sign up free at mapbox.com/signup, then copy the default public token
# from your Account page. Powers map tiles + location geocoding across the
# Alumni Map, Business Directory, Jobs and Events. Free tier covers 100k
# geocoding requests and 50k map loads per month.
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token
